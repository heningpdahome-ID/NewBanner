<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="300dp">

    <android.support.v7.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="290dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/get_Estimasi_Harga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_marginStart="42dp"
                android:layout_marginTop="24dp"
                android:text="TextView"
                android:textSize="10sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/linearLayout3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/aidi_pelanggan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="11dp"
                    android:text="TextView"
                    android:textSize="8sp"
                    android:visibility="invisible" />

                <TextView
                    android:id="@+id/aidi_detail_pesanan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@+id/aidi_pelanggan"
                    android:layout_marginStart="33dp"
                    android:layout_marginTop="11dp"
                    android:layout_toEndOf="@+id/aidi_pelanggan"
                    android:text="TextView"
                    android:textSize="8sp"
                    android:visibility="invisible" />

                <TextView
                    android:id="@+id/aidi_template"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignBaseline="@+id/aidi_detail_pesanan"
                    android:layout_alignBottom="@+id/aidi_detail_pesanan"
                    android:layout_marginLeft="95dp"
                    android:layout_marginTop="11dp"
                    android:layout_toStartOf="@+id/get_Finishing"
                    android:text="TextView"
                    android:textSize="8sp"
                    android:visibility="invisible" />

                <TextView
                    android:id="@+id/aidi_skema_warna"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignTop="@+id/aidi_template"
                    android:layout_marginLeft="105dp"
                    android:layout_marginTop="11dp"
                    android:text="TextView"
                    android:textSize="8sp"
                    android:visibility="invisible" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="55dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/get_Image"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_alignStart="@+id/aidi_pelanggan"
                    android:layout_alignTop="@+id/get_Konten"
                    android:layout_marginLeft="35dp"
                    app:srcCompat="@mipmap/ic_launcher" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="100dp"
                    android:layout_marginLeft="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/get_Header"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/aidi_template"
                        android:layout_centerHorizontal="true"
                        android:layout_marginLeft="40dp"
                        android:layout_marginTop="2dp"
                        android:text="TextView" />

                    <TextView
                        android:id="@+id/get_Konten"
                        android:layout_width="120dp"
                        android:layout_height="40dp"
                        android:layout_below="@+id/aidi_template"
                        android:layout_centerHorizontal="true"
                        android:layout_marginLeft="40dp"
                        android:layout_marginTop="12dp"
                        android:text="TextView" />

                    <TextView
                        android:id="@+id/get_Subtitle"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/aidi_template"
                        android:layout_centerHorizontal="true"
                        android:layout_marginLeft="40dp"
                        android:layout_marginTop="12dp"
                        android:text="TextView" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:visibility="gone"
                android:id="@+id/get_Finishing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@+id/linearLayout2"
                android:layout_alignParentEnd="true"
                android:layout_marginBottom="-190dp"
                android:layout_marginEnd="13dp"
                android:text="TextView" />

            <LinearLayout
                android:id="@+id/linearLayout2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginBottom="12dp"
                android:layout_marginLeft="2dp"
                android:layout_marginRight="2dp"
                android:layout_marginTop="190dp">

                <TextView
                    android:id="@+id/get_Jumlah_Pesanan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="23dp"
                    android:layout_marginLeft="10dp"
                    android:layout_toStartOf="@+id/aidi_detail_pesanan"
                    android:text="TextView"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp">

                    <TextView
                        android:id="@+id/get_Width"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="80dp"
                        android:text="TextView"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/get_Height"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="40dp"

                        android:text="TextView"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>


            </LinearLayout>

            <TextView
                android:id="@+id/get_Time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@+id/get_Estimasi_Harga"
                android:layout_marginEnd="42dp"
                android:text="TextView"
                android:textSize="10sp" />


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_alignEnd="@+id/linearLayout2"
                android:layout_below="@+id/linearLayout2">



                <Button
                    android:id="@+id/Pri_Pesan"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginEnd="22dp"
                    android:layout_marginLeft="15dp"
                    android:layout_toStartOf="@+id/Pri_Batal"
                    android:text="Pesan"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/Pri_Batal"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="36dp"
                    android:background="@color/hakai"
                    android:text="Batal"
                    android:textColor="@color/white" />


            </RelativeLayout>

        </RelativeLayout>
    </android.support.v7.widget.CardView>

</LinearLayout>