<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="255dp"
    android:background="@color/abue">


    <android.support.v7.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="245dp"
        >



        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_marginRight="15dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/aidepes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_gravity="start"
                    android:layout_marginTop="16dp"
                    android:layout_toEndOf="@+id/cont_riw"
                    android:text="TextView"
                    android:textColor="@color/mags"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_gravity="end"
                    android:id="@+id/tgl_riw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_marginTop="16dp"
                    android:layout_toEndOf="@+id/cont_riw"
                    android:text="TextView"
                    android:textSize="12sp" />

            </LinearLayout>


            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/im_riw"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="18dp"
                app:srcCompat="@mipmap/ic_launcher" />
                <LinearLayout
                    android:layout_marginLeft="30dp"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/hea_riw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignStart="@+id/cont_riw"
                    android:layout_alignTop="@+id/im_riw"
                    android:text="TextView" />

                <TextView
                    android:layout_marginTop="20dp"
                    android:id="@+id/cont_riw"
                    android:layout_width="120dp"
                    android:layout_height="20dp"
                    android:layout_alignStart="@+id/subt_riw"
                    android:layout_centerVertical="true"
                    android:text="TextView" />

                <TextView
                    android:layout_marginTop="20dp"
                    android:id="@+id/subt_riw"
                    android:layout_width="70dp"
                    android:layout_height="20dp"
                    android:layout_alignBottom="@+id/im_riw"
                    android:layout_marginEnd="15dp"
                    android:layout_toStartOf="@+id/Sta_riw"
                    android:text="TextView" />
                </LinearLayout>
            </LinearLayout>
<LinearLayout
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<LinearLayout
    android:layout_marginLeft="20dp"
    android:layout_marginTop="20dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
            <TextView
                android:id="@+id/qua_riw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_alignStart="@+id/subt_riw"
                android:layout_marginBottom="19dp"
                android:text="TextView" />
</LinearLayout>

<LinearLayout
    android:layout_marginLeft="190dp"
    android:layout_marginTop="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

            <TextView
                android:layout_gravity="end"
                android:id="@+id/Sta_riw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBaseline="@+id/qua_riw"
                android:layout_alignBottom="@+id/qua_riw"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="2dp"
                android:text="TextView"
                android:textSize="14sp"
                android:textStyle="bold" />
</LinearLayout>


</LinearLayout>

        </LinearLayout>
    </android.support.v7.widget.CardView>

</RelativeLayout>