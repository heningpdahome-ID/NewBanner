<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.example.eternal.newbanner.SwaPesan.TemplatePesan">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
    <LinearLayout
        android:layout_gravity="end"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <Spinner
            android:id="@+id/Cara"
            android:layout_width="150dp"
            android:layout_height="wrap_content">

        </Spinner>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center"
        android:layout_marginTop="40dp">
        <TextView
            android:id="@+id/text_Gam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pick Img"/>

        <ImageView
            android:layout_marginLeft="10dp"
            android:id="@+id/Gam"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:src="@mipmap/ic_launcher" />
    </LinearLayout>

        <LinearLayout
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">
            <Switch
                android:id="@+id/Witch"
                android:text="Ada Tambahan File ? "
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textOn="Ada"
                android:textOff="Tak"/>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="20dp"
            android:id="@+id/Img_Logo"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">
            <TextView
                android:id="@+id/text_Logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick Img"/>
            <ImageView
                android:layout_marginLeft="10dp"
                android:id="@+id/Logo"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:src="@mipmap/ic_launcher" />
        </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/Heade"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:hint="Tuliskan Header" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/Cont"
            android:layout_width="220dp"
            android:layout_height="70dp"
            android:hint="Tuliskan Konten" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/Subti"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:hint="Tuliskan Subtitle" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp">

        <Spinner
            android:id="@+id/Ingre"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/Har"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:text="TextView" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/B"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp">


        <EditText
            android:id="@+id/Wid"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:hint="Lebar"
            android:inputType="number" />

        <TextView
            android:layout_marginLeft="15dp"
            android:id="@+id/CM1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="cm"/>

        <EditText
            android:id="@+id/Hei"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:ems="10"
            android:hint="Tinggi"
            android:inputType="number" />

        <TextView
            android:layout_marginLeft="15dp"
            android:id="@+id/CM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="cm"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/XB"
        android:layout_marginTop="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Spinner
            android:layout_marginLeft="20dp"
            android:id="@+id/Ukurane"
            android:layout_width="120dp"
            android:layout_height="wrap_content"/>
        <TextView
            android:layout_marginLeft="25dp"
            android:id="@+id/Price_Ukuran"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rego Ukuran"/>
    </LinearLayout>
        <LinearLayout
            android:id="@+id/Line_Jagrak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="20dp">
            <RadioGroup
                android:id="@+id/Rad_Jagrak"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RadioButton
                    android:id="@+id/Yes_Jagrak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Include_Jagrakan"/>
                <RadioButton
                    android:id="@+id/No_Jagrak"
                    android:layout_marginLeft="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Non_Jagrakan"/>
            </RadioGroup>

        </LinearLayout>
    <LinearLayout
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <EditText
            android:id="@+id/Quan"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:ems="10"
            android:hint="Jml"
            android:inputType="number" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="20dp">

        <RadioGroup
            android:id="@+id/Ragru"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/Fin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mata Ayam" />

            <RadioButton
                android:id="@+id/Non"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:text="Tanpa Finishing" />
        </RadioGroup>



    </LinearLayout>
    <LinearLayout
        android:layout_marginTop="2dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/Opsi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Text"/>
    </LinearLayout>

    <TextView
        android:id="@+id/choose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="choose"
        android:visibility="invisible"
        />





    <TextView
        android:id="@+id/Rego"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:text="TextView"
        android:textSize="18sp"
        android:textStyle="bold" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/Keterangan_Tambahan"
                android:hint="Masukkan Keterangan Tambahan"
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">
        <Button
            android:textColor="@color/white"
            android:background="@color/pesa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Pes"
            android:text="Pesan"/>
    </LinearLayout>



    </LinearLayout>
    </ScrollView>

</LinearLayout>
